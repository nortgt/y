-- ---ЧАТ---
local target = ""
local function chat(m)
    local tcs = game:GetService("TextChatService")
    if tcs.ChatVersion == Enum.ChatVersion.TextChatService then
        tcs.TextChannels.RBXGeneral:SendAsync(m)
    else
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(m, "All")
    end
end

-- ---РЕНДЕР---
local function AddItem(m)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(0, 220, 0, 60)
    f.BackgroundTransparency = 1
    f.Parent = List

    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 175, 0, 60)
    b.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
    b.Text = m:upper()
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.Font = "SourceSansBold"
    b.TextSize = 20
    b.Parent = f
    Round(b)

    local d = Instance.new("TextButton")
    d.Size = UDim2.new(0, 40, 0, 60)
    d.Position = UDim2.new(0, 180, 0, 0)
    d.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
    d.Text = "X"
    d.Parent = f
    Round(d)

    b.MouseButton1Click:Connect(function() target = m; Conf.Visible = true end)
    d.MouseButton1Click:Connect(function()
        for i, v in ipairs(binds) do if v == m then table.remove(binds, i); break end end
        save(); f:Destroy()
    end)
    List.CanvasSize = UDim2.new(0, 0, 0, Lay.AbsoluteContentSize.Y + 20)
end

-- ---СТАРТ---
binds = load()
for _, v in ipairs(binds) do AddItem(v) end

AddBtn.MouseButton1Click:Connect(function() Inp.Visible = not Inp.Visible end)
Go.MouseButton1Click:Connect(function()
    if Box.Text ~= "" then
        table.insert(binds, Box.Text)
        save(); AddItem(Box.Text)
        Box.Text = ""; Inp.Visible = false
    end
end)

Yes.MouseButton1Click:Connect(function() chat(target); Conf.Visible = false end)
No.MouseButton1Click:Connect(function() Conf.Visible = false end)
ExitBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

