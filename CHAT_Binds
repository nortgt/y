local HttpService = game:GetService("HttpService")
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "MyBinds"
ScreenGui.Parent = game.CoreGui
ScreenGui.DisplayOrder = 100

local FILE = "binds_data.txt"
local binds = {}

-- ---ЭТО ВИЗУАЛ---
local function Round(obj)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 10)
    c.Parent = obj
end

-- ---РАБОТА С ФАЙЛАМИ---
local function save()
    writefile(FILE, HttpService:JSONEncode(binds))
end

local function load()
    if isfile(FILE) then
        local s, r = pcall(function() return HttpService:JSONDecode(readfile(FILE)) end)
        return s and r or {}
    end
    return {}
end

