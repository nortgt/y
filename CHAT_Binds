local function MakeBtn(txt, pos, clr)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 35, 0, 35)
    b.Position = pos
    b.BackgroundColor3 = clr or Color3.fromRGB(80, 80, 80)
    b.Text = txt
    b.TextSize = 25
    b.ZIndex = 3
    b.Parent = Head
    Round(b)
    return b
end

