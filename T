local function CreateAura()
    local torso = chara:WaitForChild("Torso") or chara:WaitForChild("UpperTorso")
    local humanoid = chara:WaitForChild("Humanoid")
    
    local auraPart1 = New("Part", chara, "AuraPart1", {
        Size = Vector3.new(2, 2, 1),
        Transparency = 1,
        CanCollide = false,
        Anchored = false
    })
    
    local auraPart2 = New("Part", chara, "AuraPart2", {
        Size = Vector3.new(1, 2, 1),
        Transparency = 1,
        CanCollide = false,
        Anchored = false
    })
    
    local auraPart3 = New("Part", chara, "AuraPart3", {
        Size = Vector3.new(1, 2, 1),
        Transparency = 1,
        CanCollide = false,
        Anchored = false
    })
    
    local weld1 = Instance.new("Weld")
    weld1.Part0 = torso
    weld1.Part1 = auraPart1
    weld1.C0 = CFrame.new(0, 0, 0)
    weld1.Parent = auraPart1
    
    local weld2 = Instance.new("Weld")
    weld2.Part0 = torso
    weld2.Part1 = auraPart2
    weld2.C0 = CFrame.new(1.5, 0, 0)
    weld2.Parent = auraPart2
    
    local weld3 = Instance.new("Weld")
    weld3.Part0 = torso
    weld3.Part1 = auraPart3
    weld3.C0 = CFrame.new(-1.5, 0, 0)
    weld3.Parent = auraPart3
    
    BurningEff(auraPart1)
    BurningEff(auraPart2)
    BurningEff(auraPart3)
    
    RunService.Heartbeat:Connect(function()
        if humanoid and humanoid.Health > 0 then
            local jtrace = Instance.new("Part", workspace)
            jtrace.Name = "AuraTrace"
            jtrace.Size = Vector3.new(10, 0, 10)
            jtrace.Position = torso.Position
            jtrace.CFrame = torso.CFrame - Vector3.new(0, 3, 0)
            jtrace.Anchored = true
            jtrace.CanCollide = false
            jtrace.Transparency = 1
            BurningEff(jtrace)
            game:GetService("Debris"):AddItem(jtrace, 1)
        end
    end)
end

local function CreateFloatingName()
    local head = chara:WaitForChild("Head")
    local humanoid = chara:WaitForChild("Humanoid")
    
    local nameGui = New("BillboardGui", chara, "NameTag", {
        Size = UDim2.new(0, 100, 0, 40),
        StudsOffset = Vector3.new(0, 2, 0),
        Adornee = head
    })
    
    local nameLabel = New("TextLabel", nameGui, "NameLabel", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = "John Doe",
        Font = Enum.Font.Fantasy,
        TextSize = 24,
        TextStrokeTransparency = 0,
        TextStrokeColor3 = Color3.new(0, 0, 0),
        TextColor3 = Color3.new(0, 0, 0),
        Size = UDim2.new(1, 0, 0.5, 0)
    })
    
    coroutine.wrap(function()
        while humanoid and humanoid.Health > 0 do
            wait(0.1)
            local chance = math.random(0, 100)
            if chance < 10 then
                local sel = math.random(1, 3)
                if sel == 1 then
                    nameLabel.Text = "NOHOPE"
                elseif sel == 2 then
                    nameLabel.Text = "GIVEUP"
                elseif sel == 3 then
                    nameLabel.Text = "BLACKHOLE"
                end
            else
                nameLabel.Text = "Emma"
            end
            
            nameLabel.Position = UDim2.new(0, math.random(-3, 3), 0, math.random(-3, 3))
        end
    end)()
    
    return nameGui, nameLabel
end

local function CreateSkybox()
    local skybox = New("Part", chara, "SkyboxPart", {
        Size = Vector3.new(0, 0, 0),
        Anchored = true,
        CanCollide = false,
        Position = Vector3.new(0, 0, 0)
    })
    
    local skyboxMesh = New("SpecialMesh", skybox, "Mesh", {
        MeshId = "http://www.roblox.com/asset/?id=1527559",
        TextureId = "http://www.roblox.com/asset/?id=1529455",
        VertexColor = Vector3.new(1, 0, 0),
        Scale = Vector3.new(-3000, -1000, -3000)
    })
    
    coroutine.wrap(function()
        while skybox and skybox.Parent do
            wait(0.1)
            skybox.CFrame = skybox.CFrame * CFrame.fromEulerAnglesXYZ(0, math.rad(1), 0)
        end
    end)()
    
    return skybox
end

local function SetupDeathEffects()
    local humanoid = chara:WaitForChild("Humanoid")
    local torso = chara:WaitForChild("Torso") or chara:WaitForChild("UpperTorso")
    local nameGui = chara:FindFirstChild("NameTag")
    local nameLabel = nameGui and nameGui:FindFirstChild("NameLabel")
    
    humanoid.Died:Connect(function()
        local originalOutdoorAmbient = Lighting.OutdoorAmbient
        local originalTimeOfDay = Lighting.TimeOfDay
        local originalFogColor = Lighting.FogColor
        local originalFogEnd = Lighting.FogEnd
        
        if nameLabel then
            nameLabel.Text = "BAD ENDING"
            nameLabel.TextSize = 48
            nameLabel.TextColor3 = Color3.new(1, 0, 0)
        end
        
        Lighting.OutdoorAmbient = Color3.new(0, 0, 0)
        Lighting.TimeOfDay = "00:00:00"
        Lighting.FogColor = Color3.new(0, 0, 0)
        Lighting.FogEnd = 1000
        
        wait(5)
        Lighting.OutdoorAmbient = originalOutdoorAmbient
        Lighting.TimeOfDay = originalTimeOfDay
        Lighting.FogColor = originalFogColor
        Lighting.FogEnd = originalFogEnd
    end)
end

