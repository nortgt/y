-- Funciones auxiliares
local function createAttachment(name, parent, position, axis, secondaryAxis)
    local att = Instance.new("Attachment")
    att.Name = name
    att.Parent = parent
    att.Position = position or Vector3.new(0, 0, 0)
    att.Visible = false
    if axis then att.Axis = axis end
    if secondaryAxis then att.SecondaryAxis = secondaryAxis end
    return att
end

local function createParticleEmitter(name, parent, data)
    local pe = Instance.new("ParticleEmitter")
    pe.Name = name
    pe.Parent = parent
    
    pe.Enabled = data.Enabled ~= nil and data.Enabled or true
    if data.Transparency then pe.Transparency = data.Transparency end
    if data.Brightness then pe.Brightness = data.Brightness end
    if data.Color then pe.Color = data.Color end
    if data.Size then pe.Size = data.Size end
    if data.Lifetime then pe.Lifetime = data.Lifetime end
    if data.Rate then pe.Rate = data.Rate end
    if data.Speed then pe.Speed = data.Speed end
    if data.Drag then pe.Drag = data.Drag end
    if data.LockedToPart ~= nil then pe.LockedToPart = data.LockedToPart end
    if data.LightEmission then pe.LightEmission = data.LightEmission end
    if data.LightInfluence then pe.LightInfluence = data.LightInfluence end
    if data.Texture then pe.Texture = data.Texture end
    if data.ZOffset then pe.ZOffset = data.ZOffset end
    if data.TimeScale then pe.TimeScale = data.TimeScale end
    
    return pe
end

local function createBeam(name, attachment0, attachment1, data)
    local beam = Instance.new("Beam")
    beam.Name = name
    beam.Attachment0 = attachment0
    beam.Attachment1 = attachment1
    beam.Parent = attachment0.Parent
    
    beam.Enabled = data.Enabled ~= nil and data.Enabled or true
    if data.Transparency then beam.Transparency = data.Transparency end
    if data.Brightness then beam.Brightness = data.Brightness end
    if data.Color then beam.Color = data.Color end
    if data.LightEmission then beam.LightEmission = data.LightEmission end
    if data.LightInfluence then beam.LightInfluence = data.LightInfluence end
    if data.Texture then beam.Texture = data.Texture end
    if data.FaceCamera ~= nil then beam.FaceCamera = data.FaceCamera end
    if data.ZOffset then beam.ZOffset = data.ZOffset end
    
    return beam
end

local function createInvisiblePart(name, size, cframe)
    local part = Instance.new("Part")
    part.Name = name
    part.Parent = character
    part.Size = size
    part.CFrame = cframe
    part.Transparency = 1
    part.Anchored = true
    part.CanCollide = false
    part.Massless = true
    return part
end

