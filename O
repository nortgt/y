local function createInvisiblePart(name, size, cframe)
    local part = Instance.new("Part")
    part.Name = name
    part.Parent = character
    part.Size = size
    part.CFrame = cframe
    part.Transparency = 1
    part.Anchored = true
    part.CanCollide = false
    part.Massless = true
    part.BrickColor = BrickColor.new("Medium stone grey")
    return part
end

