end

-- Sistema ragdoll
function Commands.ragdoll(targetName)
    local char = getChar(targetName)
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("Motor6D") then
            local part0 = v.Part0
            local part1 = v.Part1

            local a0 = Instance.new("Attachment")
            a0.CFrame = v.C0
            a0.Parent = part0

            local a1 = Instance.new("Attachment")
            a1.CFrame = v.C1
            a1.Parent = part1

            local socket = Instance.new("BallSocketConstraint")
            socket.Attachment0 = a0
            socket.Attachment1 = a1
            socket.Parent = part0

            v.Enabled = false
        end
    end

    hum:ChangeState(Enum.HumanoidStateType.Physics)
    print("Ragdoll en " .. targetName)
end

function Commands.unragdoll(targetName)
    local char = getChar(targetName)
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BallSocketConstraint") then
            v:Destroy()
        end
        if v:IsA("Attachment") then
            v:Destroy()
        end
    end

    for _, motor in ipairs(char:GetDescendants()) do
        if motor:IsA("Motor6D") then
            motor.Enabled = true
        end
    end

    hum.PlatformStand = false
    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    print("Ragdoll removido de " .. targetName)
end

-- Loop kills
local LoopKills = {}

function Commands.angel(targetName)
    local name = LocalPlayer.Name
    if LoopKills[name] then
        return
    end
    LoopKills[name] = true

    task.spawn(function()
        while LoopKills[name] do
            local char = getChar(targetName)
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                char:BreakJoints()
            end
            task.wait(0.4)
        end
    end)
    print("Angel activado")
end

function Commands.unangel(targetName)
    local name = LocalPlayer.Name
    LoopKills[name] = nil
    print("Angel desactivado")
end

-- Loop sit
local loopsitting = false

function Commands.loopsit(targetName)
    if loopsitting then return end

    loopsitting = true

    task.spawn(function()
        while loopsitting do
            local char = getChar(targetName)
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            if hum then
                if not hum.Sit then
                    hum.Sit = true
                end
            end
            task.wait(0.1)
        end
    end)
    print("Loop sit activado")
end

function Commands.unloopsit(targetName)
    if not loopsitting then return end

    loopsitting = false

    local char = getChar(targetName)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Sit = false
    end
    print("Loop sit desactivado")
end

-- ==========================================
-- SISTEMA DE PROCESAMIENTO DE COMANDOS
-- ==========================================

-- Configuración de permisos (opcional - similar a Developer en tu chat)
local Admins = {
    "Deluxe_Studios",
    "Roun95"
    -- Agrega aquí los nombres de los administradores
}

-- Función para verificar si un usuario es administrador
local function isAdmin(username)
    for _, admin in ipairs(Admins) do
        if username == admin then
            return true
        end
    end
    return false
end

-- Función para procesar un comando
local function processCommand(commandText, sender)
    -- Verificar permisos (solo admins pueden usar comandos)
    if not isAdmin(sender) then
        print("Usuario sin permisos: " .. sender .. " intentó usar: " .. commandText)
        return false
    end

    -- Extraer comando y argumentos
    local cmd, target = commandText:match("^%s*(%S+)%s*(.*)$")
    if not cmd then return false end
    
    -- Eliminar cualquier prefijo si existe
    cmd = cmd:gsub("^[:!]", "")
    
    print("Procesando comando: " .. cmd .. " | Objetivo: " .. target)

    -- Ejecutar el comando
    if Commands[cmd] then
        -- Si el comando es 'verify' no necesita target
        if cmd == "verify" then
            Commands[cmd]()
        else
            Commands[cmd](target)
        end
        return true
    else
        print("Comando desconocido: " .. cmd)
        return false
    end
end

-- ==========================================
-- INTEGRACIÓN CON NOVA CHAT
-- ==========================================

-- Esperar a que el chat esté listo
local function setupChatCommands()
    print("Configurando sistema de comandos para Nova Chat...")
    
    -- Guardar la función original de manejo de mensajes
    local originalOnMessage = getgenv().novachat.OnMessage
    
    -- Reemplazar con nuestra versión que procesa comandos
    getgenv().novachat.OnMessage:Connect(function(msg)
        -- Procesar el mensaje normalmente primero
        local success, Decoded = pcall(HttpService.JSONDecode, HttpService, msg)
        if not success then
            warn("Failed to decode message:", msg)
            return
        end
        
        -- Verificar si es un comando (los comandos empiezan con ':' o '!')
        if Decoded.message and (string.sub(Decoded.message, 1, 1) == ":" or string.sub(Decoded.message, 1, 1) == "!") then
            -- Procesar el comando
            processCommand(Decoded.message, Decoded.username)
        end
        
        -- Continuar con el procesamiento normal del mensaje
        -- Aquí va el código original de creación del mensaje en el chat
        -- (El código que ya tienes en tu Nova Chat para mostrar mensajes)
    end)
    
    print("Sistema de comandos listo!")
end

-- Iniciar la integración cuando el chat esté disponible
task.spawn(function()
    -- Esperar a que el chat esté inicializado
    while not getgenv().novachat do
        task.wait(1)
    end
    
    -- Esperar un poco más para asegurar que todo esté listo
    task.wait(2)
    setupChatCommands()
end)

return G2L.ScreenGui
