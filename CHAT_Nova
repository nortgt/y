local function isAdmin(username)
    for _, admin in ipairs(Admins) do
        if username == admin then return true end
    end
    return false
end

local function getTarget(targetName)
    if not targetName or targetName == "" then
        return Players.LocalPlayer.Character
    end
    local player = Players:FindFirstChild(targetName)
    return player and player.Character
end

function Commands.kill(targetName)
    local char = getTarget(targetName)
    if char then
        char:BreakJoints()
    end
end

local ActiveJails = {}
local JailLoops = {}

function Commands.jail(targetName)
    if not targetName or targetName == "" then return end
    
    local char = getTarget(targetName)
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local basePos = root.Position
    ActiveJails[targetName] = {}

    local positions = {
        {Vector3.new(5,0,0), Vector3.new(1,10,10)},
        {Vector3.new(-5,0,0), Vector3.new(1,10,10)},
        {Vector3.new(0,0,5), Vector3.new(10,10,1)},
        {Vector3.new(0,0,-5), Vector3.new(10,10,1)},
        {Vector3.new(0,5,0), Vector3.new(10,1,10)},
        {Vector3.new(0,-5,0), Vector3.new(10,1,10)}
    }
    
    for _, data in pairs(positions) do
        local p = Instance.new("Part")
        p.Anchored = true
        p.Size = data[2]
        p.CFrame = CFrame.new(basePos + data[1])
        p.Transparency = 0.5
        p.Color = Color3.new(0, 0, 0)
        p.Parent = workspace
        table.insert(ActiveJails[targetName], p)
    end
    
    if char == Players.LocalPlayer.Character then
        JailLoops[targetName] = game:GetService("RunService").Heartbeat:Connect(function()
            if char and root and (root.Position - basePos).Magnitude > 4.5 then
                root.CFrame = CFrame.new(basePos)
            end
        end)
    end
end

function Commands.unjail(targetName)
    if not targetName or targetName == "" then return end
    
    if ActiveJails[targetName] then
        for _, part in ipairs(ActiveJails[targetName]) do
            part:Destroy()
        end
        ActiveJails[targetName] = nil
    end
    
    if JailLoops[targetName] then
        JailLoops[targetName]:Disconnect()
        JailLoops[targetName] = nil
    end
end

function Commands.freeze(targetName)
    local char = getTarget(targetName)
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Anchored = true
        end
    end
end

function Commands.unfreeze(targetName)
    local char = getTarget(targetName)
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Anchored = false
        end
    end
end

function Commands.warn(args)
    if not args or args == "" then return end
    
    local targetName, reason = args:match("^(%S+)%s*(.-)$")
    if not targetName then
        targetName = args
        reason = "No reason provided"
    end
    
    local targetPlayer = Players:FindFirstChild(targetName)
    if not targetPlayer then return end

    local DataContent = {
        type = "message",
        username = "Admin",
        message = targetPlayer.Name .. " has been warned by " .. Player.Name .. " for " .. reason,
        userid = 1,
        gamePlaying = "Server",
        gameid = game.PlaceId
    }

    getgenv().novachat:Send(HttpService:JSONEncode(DataContent))
end

function Commands.music()
    local SoundService = game:GetService("SoundService")
    local audioUrl = "https://raw.githubusercontent.com/nxvap/cdn/db/data/cjnobeat.mp3"
    
    local getAsset = getcustomasset or getsynasset or function(path) return "rbxasset://" .. path end
    local fileName = audioUrl:match("([^/]+)$")
    
    if not pcall(function() return readfile(fileName) ~= nil end) then
        local success, data = pcall(function()
            return game:HttpGet(audioUrl)
        end)
        if success and data then
            pcall(function() writefile(fileName, data) end)
        end
    end
    
    local sound = Instance.new("Sound")
    sound.SoundId = getAsset(fileName)
    sound.Volume = 1
    sound.Looped = false
    sound.Parent = SoundService
    sound:Play()
    
    notify("MUSIC", "Playing sound", 3)
end

