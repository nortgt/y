local function ProcessCommand(message, username)
    if string.sub(message, 1, 1) ~= ":" then return end
	
    local isLocalUser = (username == Player.Name)
	
    if not isAdmin(username) then
	    if isLocalUser then notify("⛔ Access blocked: You do not have permission ", username) end
        return
    end
    
    local cmd, args = message:match("^:(%S+)%s*(.*)$")
    if not cmd then
        cmd = message:match("^:(%S+)$")
    end
    
    if not cmd then return end
    
    cmd = cmd:lower()
    
    if Commands[cmd] then
        local success, err = pcall(function()
            Commands[cmd](args)
            if isLocalUser then notify("✅ SUCCESS", "Command :" .. cmd .. " executed successfully", 3) end
        end)
		
        if not success then
            warn("❌ COMMAND ERROR: " .. cmd .. ":", err)
			if isLocalUser then notify("❌ ERROR", "There was an error while executing the command: " .. cmd, 4) end
        end
    else
		if isLocalUser then notify("❓ ERROR", "Command not found: " .. cmd .. "\nUse info to see the list of commands", 5) end
    end
end

