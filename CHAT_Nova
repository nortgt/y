-- Sistema de jail
local ActiveJails = {}
local JailLoops = {}

function Commands.jail(targetName)
    local char = getChar(targetName)
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local basePos = root.Position
    ActiveJails[targetName] = {}

    local positions = {
        {Vector3.new(5,0,0), Vector3.new(1,10,10)},
        {Vector3.new(-5,0,0), Vector3.new(1,10,10)},
        {Vector3.new(0,0,5), Vector3.new(10,10,1)},
        {Vector3.new(0,0,-5), Vector3.new(10,10,1)},
        {Vector3.new(0,5,0), Vector3.new(10,1,10)},
        {Vector3.new(0,-5,0), Vector3.new(10,1,10)}
    }
    
    for _, data in pairs(positions) do
        local p = Instance.new("Part")
        p.Anchored = true
        p.Size = data[2]
        p.CFrame = CFrame.new(basePos + data[1])
        p.Transparency = 0.5
        p.Color = Color3.new(0,0,0)
        p.Parent = workspace
        table.insert(ActiveJails[targetName], p)
    end
    
    if char == LocalPlayer.Character then
        JailLoops[targetName] = RunService.Heartbeat:Connect(function()
            if char and root and (root.Position - basePos).Magnitude > 5 then
                root.CFrame = CFrame.new(basePos)
            end
        end)
    end
    print("Jugador " .. targetName .. " encarcelado")
end

function Commands.unjail(targetName)
    if ActiveJails[targetName] then
        for _, part in ipairs(ActiveJails[targetName]) do
            part:Destroy()
        end
        ActiveJails[targetName] = nil
    end
    
    if JailLoops[targetName] then
        JailLoops[targetName]:Disconnect()
        JailLoops[targetName] = nil
    end
    print("Jugador " .. targetName .. " liberado")
end

