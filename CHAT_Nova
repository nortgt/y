--// Lógica Principal
local function MainFunction()
    local NoticeSound = Create("Sound", {
		SoundId = "rbxassetid://2865226708",
		Name = "NoticeReciveSound",
		Parent = G2L.ScreenGui
	})
    
    local SendSound = Create("Sound", {
		SoundId = "rbxassetid://5485567028",
		Name = "SendSound",
		Parent = G2L.ScreenGui
	})
    
    local ChatHistory = G2L.ChatHistory
    local SendAsync = G2L.SendButton
    local SourceChat = G2L.SourceChat
    
    local Developer = {
        "C00lHamo0t2025",
        "ikik9i4"
    }

    local function CheckIfAdmin(player)
        return table.find(Developer, player.Name) ~= nil
    end

    local function FindPlayer(str)
        str = string.lower(str)
        for _, plr in ipairs(Players:GetPlayers()) do
            if string.sub(string.lower(plr.Name), 1, #str) == str then
                return plr
            end
        end
    end

    function AdminArg.Ban(player)
        if not CheckIfAdmin(Player) or not player then return end
        table.insert(BannedPeople, player.UserId)
    end

    function AdminArg.warn(player, reason)
        if not CheckIfAdmin(Player) or not player then return end

        local DataContent = {
            type = "message",
            username = "Server",
            message = player.Name .. " has been warned by " .. Player.Name .. " for " .. (reason or "No reason"),
            userid = 1,
            gamePlaying = "DataBase",
            gameid = game.PlaceId
        }

        getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
    end

    function AdminArg.unban(player)
        if not CheckIfAdmin(Player) or not player then return end

        local index = table.find(BannedPeople, player.UserId)
        if index then
            table.remove(BannedPeople, index)
        end
    end

    local AdminCommands = {
        ban = AdminArg.Ban,
        warn = AdminArg.warn,
        unban = AdminArg.unban
    }

    local function HandleCommand(text)
        local split = string.split(text, " ")
        if split[1] ~= "?" then return end

        local targetPlayer = FindPlayer(split[3])
        if AdminCommands[split[2]] then
            AdminCommands[split[2]](targetPlayer, split[4])
        end
    end

	-- Conexión WebSocket
    getgenv().trezchat = WebSocket.connect("wss://free.blr2.piesocket.com/v3/1?api_key=eLudeCBiiTiQSr6DWJPMPfpZK9B6ghEu90ZbJwzm&notify_self=1")

    local function sendMessage()
        local text = SourceChat.Text
		if text:gsub(" ", "") == "" then return end
        
        HandleCommand(text)

        task.spawn(function()
            local DataContent = {
                type = "message",
                username = Player.Name,
                message = text,
                userid = Player.UserId,
                gamePlaying = MarketplaceService:GetProductInfo(game.PlaceId).Name,
                gameid = game.PlaceId
            }
            
            local success, result = pcall(function()
                getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
            end)
            
            if not success then
                warn("Failed to send message:", result)
            end
        end)

        SendSound:Play()
        SourceChat.Text = ""
    end

    SendAsync.MouseButton1Click:Connect(sendMessage)
    SourceChat.FocusLost:Connect(function(enterPressed)
        if enterPressed then sendMessage() end
    end)

    getgenv().trezchat.OnMessage:Connect(function(msg)
        local success, Decoded = pcall(HttpService.JSONDecode, HttpService, msg)
        if not success then
            warn("Failed to decode message:", msg)
            return
        end

        -- Crear mensaje dinámico usando la función Create
        local MessageFrame = Create("Frame", {
			Name = (Decoded.username or "Unknown") .. "_Message",
			BackgroundTransparency = 1,
			Size = UDim2.new(1, -10, 0, 50),
			Parent = ChatHistory
		})

        local PlayerIcon = Create("ImageLabel", {
			Name = "PlayerIcon",
			BackgroundTransparency = 1,
			Size = UDim2.new(0, 35, 0, 35),
			Position = UDim2.new(0, 5, 0, 5),
			Image = "rbxthumb://type=AvatarHeadShot&id=" .. (Decoded.userid or 0) .. "&w=420&h=420",
			Parent = MessageFrame
		})

        Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = PlayerIcon })

        local isDev = table.find(Developer, Decoded.username)
        
		local SenderLabel = Create("TextLabel", {
			Name = "Sender",
			BackgroundTransparency = 1,
			Size = UDim2.new(1, -50, 0, 18),
			Position = UDim2.new(0, 45, 0, 5),
			Font = Enum.Font.SourceSansBold,
			TextSize = 15,
			TextXAlignment = Enum.TextXAlignment.Left,
			Text = isDev and (Decoded.username .. " ( Dev ) ( " .. (Decoded.gamePlaying or "N/A") .. " )") or (Decoded.username .. " ( " .. (Decoded.gamePlaying or "N/A") .. " )"),
			TextColor3 = isDev and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(255, 129, 0),
			Parent = MessageFrame
		})

        local MessageLabel = Create("TextLabel", {
			Name = "MessageSource",
			BackgroundTransparency = 1,
			Size = UDim2.new(1, -50, 0, 25),
			Position = UDim2.new(0, 45, 0, 23),
			Font = Enum.Font.SourceSans,
			TextSize = 14,
			TextColor3 = Color3.fromRGB(255, 255, 255),
			TextWrapped = true,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top,
			Text = Decoded.message or "",
			Parent = MessageFrame
		})

        -- Ajustar altura según contenido para que los mensajes largos no se corten
        local textHeight = MessageLabel.TextBounds.Y
        MessageLabel.Size = UDim2.new(1, -50, 0, math.max(25, textHeight + 5))
        MessageFrame.Size = UDim2.new(1, -10, 0, 40 + math.max(0, textHeight - 20))

        NoticeSound:Play()
    end)

    local welcomeMsg = {
        type = "message",
        username = "Server",
        message = "Make Sure To Join Our Discord Server = ( https://discord.gg/TPtrJceCva )",
        userid = 1,
        gamePlaying = "DataBase",
        gameid = game.PlaceId
    }
    getgenv().trezchat:Send(HttpService:JSONEncode(welcomeMsg))

    local messages = {
        "Be Careful Do Not Share Your Personal Info !!",
        "Make Sure To Join Our Discord Server = ( https://discord.gg/TPtrJceCva )",
        "if you saw any bug you can send the screen record of the issue to our discord server in #report channel so we can sole it"
    }
    
    task.spawn(function()
        local msgIndex = 1
        while true do
            task.wait(1000) -- Retardo de 1000 segundos
            
            local DataContent = {
                type = "message",
                username = "Server",
                message = messages[msgIndex],
                userid = 1,
                gamePlaying = "DataBase",
                gameid = game.PlaceId
            }
            
            -- pcall para evitar que el bucle se rompa si el socket se cierra
			pcall(function()
            	getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
			end)
            
            msgIndex = msgIndex + 1
            if msgIndex > #messages then
                msgIndex = 1
            end
        end
    end)
end
task.spawn(MainFunction)

--// Lógica de Arrastre (Sin Memory Leaks)
local function UIDragFunction()
    local frame = G2L.Main
    local dragging, dragInput, dragStart, startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end
task.spawn(UIDragFunction)

--// Lógica del Canvas del Chat (Scroll Automático)
local function CanvasFunction()
    local ChatHistory = G2L.ChatHistory
    local Layout = G2L.ChatLayout
    
    ChatHistory.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local function Update()
        ChatHistory.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
		-- Opcional: Hacer scroll hacia abajo automáticamente cuando llega un mensaje nuevo
		ChatHistory.CanvasPosition = Vector2.new(0, Layout.AbsoluteContentSize.Y)
    end
    
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(Update)
end
task.spawn(CanvasFunction)

