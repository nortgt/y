local function MainFunction()
    local NoticeSound = Instance.new("Sound")
    NoticeSound.SoundId = "rbxassetid://2865226708"
    NoticeSound.Name = "NoticeReciveSound"
    NoticeSound.Parent = G2L.ScreenGui
    
    local SendSound = Instance.new("Sound")
    SendSound.SoundId = "rbxassetid://5485567028"
    SendSound.Name = "SendSound"
    SendSound.Parent = G2L.ScreenGui
    
    local Main = G2L.Main
    local ChatHistory = G2L.ChatHistory
    local SendAsync = G2L.SendButton
    local SourceChat = G2L.SourceChat
    
    local Developer = {
        "Deluxe_Studios",
        "Roun95"
    }

    local function CheckIfAdmin(player)
        return table.find(Developer, player.Name) ~= nil
    end

    local function FindPlayer(str)
        str = string.lower(str)
        for _, plr in ipairs(Players:GetPlayers()) do
            if string.sub(string.lower(plr.Name), 1, #str) == str then
                return plr
            end
        end
    end

    function AdminArg.Ban(player)
        if not CheckIfAdmin(Player) or not player then return end
        table.insert(BannedPeople, player.UserId)
    end

    function AdminArg.warn(player, reason)
        if not CheckIfAdmin(Player) or not player then return end

        local DataContent = {
            type = "message",
            username = "Server",
            message = player.Name .. " has been warned by " .. Player.Name .. " for " .. (reason or "No reason"),
            userid = 1,
            gamePlaying = "DataBase",
            gameid = game.PlaceId
        }

        getgenv().novachat:Send(HttpService:JSONEncode(DataContent))
    end

    function AdminArg.unban(player)
        if not CheckIfAdmin(Player) or not player then return end

        local index = table.find(BannedPeople, player.UserId)
        if index then
            table.remove(BannedPeople, index)
        end
    end

    local AdminCommands = {
        ban = AdminArg.Ban,
        warn = AdminArg.warn,
        unban = AdminArg.unban
    }

    local function HandleCommand(text)
        local split = string.split(text, " ")
        if split[1] ~= "?" then return end

        local targetPlayer = FindPlayer(split[3])
        if AdminCommands[split[2]] then
            AdminCommands[split[2]](targetPlayer, split[4])
        end
    end

    getgenv().novachat = WebSocket.connect("wss://free.blr2.piesocket.com/v3/1?api_key=eLudeCBiiTiQSr6DWJPMPfpZK9B6ghEu90ZbJwzm&notify_self=1")

    local function sendMessage()
        if SourceChat.Text == "" then return end
        
        HandleCommand(SourceChat.Text)

        task.spawn(function()
            local DataContent = {
                type = "message",
                username = Player.Name,
                message = SourceChat.Text,
                userid = Player.UserId,
                gamePlaying = MarketplaceService:GetProductInfo(game.PlaceId).Name,
                gameid = game.PlaceId
            }
            
            local success, result = pcall(function()
                getgenv().novachat:Send(HttpService:JSONEncode(DataContent))
            end)
            
            if not success then
                warn("Failed to send message:", result)
            end
        end)

        -- SendSound:Play()
        SourceChat.Text = ""
    end

    SendAsync.MouseButton1Click:Connect(sendMessage)
    SourceChat.FocusLost:Connect(function(enterPressed)
        if enterPressed then sendMessage() end
    end)

    getgenv().novachat.OnMessage:Connect(function(msg)
        local success, Decoded = pcall(HttpService.JSONDecode, HttpService, msg)
        if not success then
            warn("Failed to decode message:", msg)
            return
        end

        local MessageFrame = Instance.new("Frame")
        MessageFrame.Name = (Decoded.username or "Unknown") .. "_Message"
        MessageFrame.BackgroundTransparency = 1
        MessageFrame.Size = UDim2.new(1, -10, 0, 50)
        MessageFrame.Parent = ChatHistory

        local PlayerIcon = Instance.new("ImageLabel")
        PlayerIcon.Name = "PlayerIcon"
        PlayerIcon.BackgroundTransparency = 1
        PlayerIcon.Size = UDim2.new(0, 35, 0, 35)
        PlayerIcon.Position = UDim2.new(0, 5, 0, 5)
        PlayerIcon.Image = "rbxthumb://type=AvatarHeadShot&id=" .. (Decoded.userid or 0) .. "&w=420&h=420"
        PlayerIcon.Parent = MessageFrame

        local IconCorner = Instance.new("UICorner")
        IconCorner.CornerRadius = UDim.new(1, 0)
        IconCorner.Parent = PlayerIcon

        local SenderLabel = Instance.new("TextLabel")
        SenderLabel.Name = "Sender"
        SenderLabel.BackgroundTransparency = 1
        SenderLabel.Size = UDim2.new(1, -50, 0, 18)
        SenderLabel.Position = UDim2.new(0, 45, 0, 5)
        SenderLabel.Font = Enum.Font.SourceSansBold
        SenderLabel.TextSize = 15
        SenderLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        if table.find(Developer, Decoded.username) then
            SenderLabel.Text = Decoded.username .. " ( Dev ) ( " .. (Decoded.gamePlaying or "N/A") .. " )"
            SenderLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
        else
            SenderLabel.Text = Decoded.username .. " ( " .. (Decoded.gamePlaying or "N/A") .. " )"
            SenderLabel.TextColor3 = Color3.fromRGB(255, 129, 0)
        end
        SenderLabel.Parent = MessageFrame

        local MessageLabel = Instance.new("TextLabel")
        MessageLabel.Name = "MessageSource"
        MessageLabel.BackgroundTransparency = 1
        MessageLabel.Size = UDim2.new(1, -50, 0, 25)
        MessageLabel.Position = UDim2.new(0, 45, 0, 23)
        MessageLabel.Font = Enum.Font.SourceSans
        MessageLabel.TextSize = 14
        MessageLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        MessageLabel.TextWrapped = true
        MessageLabel.TextXAlignment = Enum.TextXAlignment.Left
        MessageLabel.TextYAlignment = Enum.TextYAlignment.Top
        MessageLabel.Text = Decoded.message or ""
        MessageLabel.Parent = MessageFrame

        local textHeight = MessageLabel.TextBounds.Y
        MessageLabel.Size = UDim2.new(1, -50, 0, math.max(25, textHeight + 5))
        MessageFrame.Size = UDim2.new(1, -10, 0, 40 + math.max(0, textHeight - 20))

        NoticeSound:Play()
    end)

    local messages = {
        "Join our Discord ( https://discord.gg/Q9R5FDapth )",
        "!! Be careful do not share your personal info !!",
        "Use common sense. Toxicity, harassment, and offensive language are not allowed",
        "Spam, flooding, and excessive blocks of text are prohibited.",
        "External links, promotion of other servers, scripts or external services are not allowed."
    }
    
    task.spawn(function()
        local msgIndex = 1
        while true do
            task.wait(5000) 
            
            local DataContent = {
                type = "message",
                username = "Server",
                message = messages[msgIndex],
                userid = 1,
                gamePlaying = "DataBase",
                gameid = game.PlaceId
            }
            
            getgenv().novachat:Send(HttpService:JSONEncode(DataContent))
            
            msgIndex = msgIndex + 1
            if msgIndex > #messages then
                msgIndex = 1
            end
        end
    end)
end
task.spawn(MainFunction)

local function UIDragFunction()
    local frame = G2L.Main
    local dragging, dragInput, dragStart, startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end
task.spawn(UIDragFunction)

