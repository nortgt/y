local AntiFlood = {
    Config = {
        CooldownTime = 3,
        MaxRepeatedMessages = 2,
        MaxSimilarity = 0.7,
        MaxCapsPercentage = 0.7,
    },
    
    State = {
        LastMessageTime = 0,
        LastMessageContent = "",
        RepeatCount = 0,
        UserWarnings = {},
    },
    
    Check = function(self, message)
        local currentTime = os.clock()
        local playerName = Player.Name
        local issues = {}
        
        if not self.State.UserWarnings[playerName] then
            self.State.UserWarnings[playerName] = 0
        end
        
        local warnings = self.State.UserWarnings[playerName]
        
        if currentTime - self.State.LastMessageTime < self.Config.CooldownTime then
            local waitTime = math.ceil(self.Config.CooldownTime - (currentTime - self.State.LastMessageTime))
            table.insert(issues, "Cooldown " .. waitTime .. " seconds")
        end
        
        if self.State.LastMessageContent and self.State.LastMessageContent ~= "" then
            local similarity = self:CalculateSimilarity(message, self.State.LastMessageContent)
            if similarity > self.Config.MaxSimilarity then
                self.State.RepeatCount = self.State.RepeatCount + 1
                if self.State.RepeatCount >= self.Config.MaxRepeatedMessages then
                    table.insert(issues, "Do not spam messages")
                end
            else
                self.State.RepeatCount = 0
            end
        end

        local capsCount = 0
        for char in message:gmatch(".") do
            if char:match("%u") then capsCount = capsCount + 1 end
        end
        local capsRatio = #message > 0 and capsCount / #message or 0
        if capsRatio > self.Config.MaxCapsPercentage and #message > 10 then
            table.insert(issues, "Do not send too many capital letters")
        end
        
        if #issues > 0 then
            self.State.UserWarnings[playerName] = warnings + 1
            
            local warningTitle = "ANTI-FLOOD SYSTEM"
            local warningMsg = issues[1]
            
            if #issues > 1 then
                warningMsg = warningMsg .. " (+" .. (#issues-1) .. " problems more)"
            end
            
            notify(warningTitle, warningMsg, 3)
            
            if warnings >= 5 then
                self.State.LastMessageTime = currentTime + 30
                notify("🚫 ANTI-SPAM", "muted 30s for spam", 5)
                table.insert(issues, "🚫 muted 30 seconds")
            elseif warnings >= 2 then
                self.State.LastMessageTime = currentTime + 15
                notify("⚠️ WARNING #" .. warnings, "you have received " .. warnings .. " warnings for bad behavior", 4)
            end
            
            return false, issues
        end
        
        self.State.LastMessageTime = currentTime
        self.State.LastMessageContent = message
        self.State.UserWarnings[playerName] = math.max(0, warnings - 0.7)
        
        return true, {}
    end,
    
    CalculateSimilarity = function(self, text1, text2)
        if not text1 or not text2 or text1 == "" or text2 == "" then return 0 end
        
        text1 = text1:lower()
        text2 = text2:lower()
        
        if text1 == text2 then return 1 end
        
        local len1, len2 = #text1, #text2
        local maxLen = math.max(len1, len2)
        if maxLen == 0 then return 1 end
        
        local matches = 0
        for i = 1, math.min(len1, len2) do
            if text1:sub(i,i) == text2:sub(i,i) then
                matches = matches + 1
            end
        end
        
        return matches / maxLen
    end,
}

