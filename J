local player = game:GetService("Players").LocalPlayer
local chara = player.Character or player.CharacterAdded:Wait()
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

-- Función para crear objetos fácilmente
local function New(Object, Parent, Name, Data)
    local Object = Instance.new(Object)
    for Index, Value in pairs(Data or {}) do
        Object[Index] = Value
    end
    Object.Parent = Parent
    Object.Name = Name
    return Object
end

--[[======================
    2. FUNCIONES DE EFECTOS (AURA)
    ======================]]

-- Efecto de partículas quemantes (el "aura" del personaje)
local function BurningEff(part)
    local eff1 = Instance.new("ParticleEmitter", part)
    eff1.Size = NumberSequence.new(0.1)
    eff1.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(0.2, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
    eff1.LightEmission = 1
    eff1.Lifetime = NumberRange.new(1)
    eff1.Speed = NumberRange.new(0)
    eff1.Rate = 100
    eff1.Texture = "rbxassetid://347504241"
    eff1.Acceleration = Vector3.new(0, 10, 0)
    eff1.Color = ColorSequence.new(Color3.new(1, 0, 0))
    
    local eff2 = Instance.new("ParticleEmitter", part)
    eff2.Size = NumberSequence.new(0.1)
    eff2.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(0.2, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
    eff2.LightEmission = 1
    eff2.Lifetime = NumberRange.new(1)
    eff2.Speed = NumberRange.new(0)
    eff2.Rate = 100
    eff2.Texture = "rbxassetid://347504259"
    eff2.Acceleration = Vector3.new(0, 10, 0)
    eff2.Color = ColorSequence.new(Color3.new(1, 0, 0))
    
    local eff3 = Instance.new("ParticleEmitter", part)
    eff3.Size = NumberSequence.new(1)
    eff3.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
    eff3.LightEmission = 1
    eff3.Lifetime = NumberRange.new(1)
    eff3.Speed = NumberRange.new(0)
    eff3.Rate = 100
    eff3.Texture = "rbxasset://textures/particles/fire_main.dds"
    eff3.Acceleration = Vector3.new(0, 10, 0)
    eff3.Color = ColorSequence.new(Color3.new(1, 0, 0))
end

-- Crear partes con el aura (para que el personaje tenga el efecto)
local function CreateAura()
    -- Esperar a que el personaje esté completamente cargado
    local torso = chara:WaitForChild("Torso") or chara:WaitForChild("UpperTorso")
    local humanoid = chara:WaitForChild("Humanoid")
    
    -- Crear partes invisibles con el efecto de partículas
    local auraPart1 = New("Part", chara, "AuraPart1", {
        Size = Vector3.new(2, 2, 1),
        Transparency = 1,
        CanCollide = false,
        Anchored = false
    })
    
    local auraPart2 = New("Part", chara, "AuraPart2", {
        Size = Vector3.new(1, 2, 1),
        Transparency = 1,
        CanCollide = false,
        Anchored = false
    })
    
    local auraPart3 = New("Part", chara, "AuraPart3", {
        Size = Vector3.new(1, 2, 1),
        Transparency = 1,
        CanCollide = false,
        Anchored = false
    })
    
    -- Soldar las partes al torso (para que sigan al personaje)
    local weld1 = Instance.new("Weld")
    weld1.Part0 = torso
    weld1.Part1 = auraPart1
    weld1.C0 = CFrame.new(0, 0, 0)
    weld1.Parent = auraPart1
    
    local weld2 = Instance.new("Weld")
    weld2.Part0 = torso
    weld2.Part1 = auraPart2
    weld2.C0 = CFrame.new(1.5, 0, 0)
    weld2.Parent = auraPart2
    
    local weld3 = Instance.new("Weld")
    weld3.Part0 = torso
    weld3.Part1 = auraPart3
    weld3.C0 = CFrame.new(-1.5, 0, 0)
    weld3.Parent = auraPart3
    
    -- Aplicar el efecto a todas las partes
    BurningEff(auraPart1)
    BurningEff(auraPart2)
    BurningEff(auraPart3)
    
    -- También crear rastros en el suelo (como el original)
    RunService.Heartbeat:Connect(function()
        if humanoid and humanoid.Health > 0 then
            local jtrace = Instance.new("Part", workspace)
            jtrace.Name = "AuraTrace"
            jtrace.Size = Vector3.new(10, 0, 10)
            jtrace.Position = torso.Position
            jtrace.CFrame = torso.CFrame - Vector3.new(0, 3, 0)
            jtrace.Anchored = true
            jtrace.CanCollide = false
            jtrace.Transparency = 1
            BurningEff(jtrace)
            game:GetService("Debris"):AddItem(jtrace, 1)
        end
    end)
end

--[[======================
    6. NOMBRE FLOTANTE
    ======================]]

local function CreateFloatingName()
    local head = chara:WaitForChild("Head")
    local humanoid = chara:WaitForChild("Humanoid")
    
    -- Crear BillboardGui
    local nameGui = New("BillboardGui", chara, "NameTag", {
        Size = UDim2.new(0, 100, 0, 40),
        StudsOffset = Vector3.new(0, 2, 0),
        Adornee = head
    })
    
    -- Crear TextLabel
    local nameLabel = New("TextLabel", nameGui, "NameLabel", {
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = "John Doe",
        Font = Enum.Font.Fantasy,
        TextSize = 24,
        TextStrokeTransparency = 0,
        TextStrokeColor3 = Color3.new(0, 0, 0),
        TextColor3 = Color3.new(0, 0, 0),
        Size = UDim2.new(1, 0, 0.5, 0)
    })
    
    -- Bucle para cambiar el texto aleatoriamente
    coroutine.wrap(function()
        while humanoid and humanoid.Health > 0 do
            wait(0.1) -- .01 en el original, pero .1 es más eficiente
            local chance = math.random(0, 100)
            if chance < 10 then
                local sel = math.random(1, 3)
                if sel == 1 then
                    nameLabel.Text = "NOHOPE"
                elseif sel == 2 then
                    nameLabel.Text = "GIVEUP"
                elseif sel == 3 then
                    nameLabel.Text = "BURNINHELL"
                end
            else
                nameLabel.Text = "John Doe"
            end
            
            -- Efecto de temblor (opcional)
            nameLabel.Position = UDim2.new(0, math.random(-3, 3), 0, math.random(-3, 3))
        end
    end)()
    
    return nameGui, nameLabel
end

--[[======================
    7. SKYBOX PERSONALIZADO
    ======================]]

local function CreateSkybox()
    -- Crear la esfera roja gigante
    local skybox = New("Part", chara, "SkyboxPart", {
        Size = Vector3.new(0, 0, 0),
        Anchored = true,
        CanCollide = false,
        Position = Vector3.new(0, 0, 0)
    })
    
    local skyboxMesh = New("SpecialMesh", skybox, "Mesh", {
        MeshId = "http://www.roblox.com/asset/?id=1527559", -- Esfera
        TextureId = "http://www.roblox.com/asset/?id=1529455", -- Textura
        VertexColor = Vector3.new(1, 0, 0), -- Color rojo
        Scale = Vector3.new(-3000, -1000, -3000) -- Tamaño gigante
    })
    
    -- Rotar la esfera continuamente
    coroutine.wrap(function()
        while skybox and skybox.Parent do
            wait(0.1) -- .01 en el original, pero .1 es más eficiente
            skybox.CFrame = skybox.CFrame * CFrame.fromEulerAnglesXYZ(0, math.rad(1), 0)
        end
    end)()
    
    return skybox
end

--[[======================
    10. MECÁNICA DE MUERTE
    (SOLO ILUMINACIÓN)
    ======================]]

local function SetupDeathEffects()
    local humanoid = chara:WaitForChild("Humanoid")
    local torso = chara:WaitForChild("Torso") or chara:WaitForChild("UpperTorso")
    local nameGui = chara:FindFirstChild("NameTag")
    local nameLabel = nameGui and nameGui:FindFirstChild("NameLabel")
    
    humanoid.Died:Connect(function()
        -- Guardar referencias originales
        local originalOutdoorAmbient = Lighting.OutdoorAmbient
        local originalTimeOfDay = Lighting.TimeOfDay
        local originalFogColor = Lighting.FogColor
        local originalFogEnd = Lighting.FogEnd
        
        -- Si existe el nameLabel, cambiar su texto
        if nameLabel then
            nameLabel.Text = "BAD CHOICE"
            nameLabel.TextSize = 48
            nameLabel.TextColor3 = Color3.new(1, 0, 0)
        end
        
        -- Cambiar iluminación a oscura/roja
        Lighting.OutdoorAmbient = Color3.new(0, 0, 0)
        Lighting.TimeOfDay = "00:00:00"
        Lighting.FogColor = Color3.new(0, 0, 0)
        Lighting.FogEnd = 1000
        
        -- Efecto de explosión (invisible pero visual)
        local ex = Instance.new("Explosion", workspace)
        ex.Position = torso.Position
        ex.Visible = false
        ex.BlastRadius = 0 -- Sin daño real
        
        -- Esperar y restaurar (opcional, el original no restaura)
        -- Puedes comentar esto si quieres que la oscuridad sea permanente
        wait(5)
        Lighting.OutdoorAmbient = originalOutdoorAmbient
        Lighting.TimeOfDay = originalTimeOfDay
        Lighting.FogColor = originalFogColor
        Lighting.FogEnd = originalFogEnd
    end)
end

