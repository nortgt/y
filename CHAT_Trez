    local HttpRequest = http_request or request
    local PlayersService = game:GetService("Players")
    local TextChatService = game:GetService("TextChatService")
    local GeneralChannel = TextChatService:WaitForChild("TextChannels"):WaitForChild("RBXGeneral")
    local HttpService = game:GetService("HttpService")
    local RunService = game:GetService("RunService")
    local API_Url = "https://text.pollinations.ai/openai"
    local ArgsTable = {}
    
    local LocalPlayer = PlayersService.LocalPlayer
    local PlayerCharacter = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    
    local HttpService = game:GetService("HttpService")
    local PlayersService = game:GetService("Players")
    local LocalPlayer = PlayersService.LocalPlayer
    
    local DeveloperList = {
        "Deluxe_Studios",
        "Roun95"
    }
    
    local function IsAdmin(player)
        return table.find(DeveloperList, player.Name) ~= nil
    end
    
    local function FindPlayerByName(searchStr)
        searchStr = string.lower(searchStr)
        for _, player in pairs(PlayersService:GetPlayers()) do
            if string.sub(string.lower(player.Name), 1, #searchStr) == searchStr then
                return player
            end
        end
    end
    
    function AdminArguments.Ban(player)
        if not IsAdmin(LocalPlayer) then return end
        if not player then return end
        table.insert(BannedPlayers, player.UserId)
    end
    
    function AdminArguments.Warn(player, reason)
        if not IsAdmin(LocalPlayer) then return end
        if not player then return end
        
        local WarningData = {
            type = "message",
            username = "Server",
            message = player.Name .. " has been warned by " .. LocalPlayer.Name .. " for " .. (reason or "No reason"),
            userid = 1,
            gamePlaying = "DataBase",
            gameid = game.PlaceId
        }
        
        local EncodedData = HttpService:JSONEncode(WarningData)
        getgenv().trezchat:Send(EncodedData)
    end
    
    function AdminArguments.Unban(player)
        if not IsAdmin(LocalPlayer) then return end
        if not player then return end
        
        for i, bannedId in pairs(BannedPlayers) do
            if bannedId == player.UserId then
                table.remove(BannedPlayers, i)
            end
        end
    end
    
    local AdminCommandHandlers = {
        ["ban"] = AdminArguments.Ban,
        ["warn"] = AdminArguments.Warn,
        ["unban"] = AdminArguments.Unban,
    }
    
    local function ProcessCommand(text)
        local parts = string.split(text, " ")
        local prefix = parts[1]
        local command = parts[2]
        local targetName = parts[3]
        local reason = parts[4]
        
        if prefix ~= "?" then return end
        
        local targetPlayer = FindPlayerByName(targetName)
        
        if AdminCommandHandlers[command] then
            AdminCommandHandlers[command](targetPlayer, reason)
        end
    end
    
    getgenv().trezchat = WebSocket.connect("wss://free.blr2.piesocket.com/v3/1?api_key=eLudeCBiiTiQSr6DWJPMPfpZK9B6ghEu90ZbJwzm&notify_self=1")
    
    local DeveloperList = {
        "Deluxe_Studios",
        "Roun95"
    }
    
    local function SendChatMessage()
        if InputBox.Text == "" then return end
        ProcessCommand(InputBox.Text)
        local player = LocalPlayer
        
        local function FilterMessage(text)
            local success, result = pcall(function()
                local encodedWord = HttpService:UrlEncode(text)
                return game:HttpGet("https://www.purgomalum.com/service/plain?text=" .. encodedWord)
            end)
            
            if success then
                local MessageData = {
                    type = "message",
                    username = player.Name,
                    message = result,
                    userid = player.UserId,
                    gamePlaying = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
                    gameid = game.PlaceId,
                }
                local EncodedMessage = HttpService:JSONEncode(MessageData)
                getgenv().trezchat:Send(EncodedMessage)
                return
            else
                warn("Failed to filter message:", result)
            end
        end
        
        FilterMessage(InputBox.Text)
        SendSoundEffect:Play()
        InputBox.Text = ""
    end
    
    SendBtn.MouseButton1Click:Connect(SendChatMessage)
    
    InputBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            SendChatMessage()
        end
    end)
    
    getgenv().trezchat.OnMessage:Connect(function(msg)
        local success, decodedData = pcall(HttpService.JSONDecode, HttpService, msg)
        if not success then
            warn("Failed to decode message:", msg)
            return
        end
        
        local username = decodedData.username or "Unknown"
        local message = decodedData.message or ""
        local userId = decodedData.userid or 0
        local gamePlaying = decodedData.gamePlaying or "N/A"
        
        local NewMessage = TemplateMessage:Clone()
        NewMessage.Name = username .. " Chats "
        NewMessage.Parent = ChatScrollFrame
        NewMessage.MessageSource.Text = message
        NewMessage.PlayerIcon.Image = "rbxthumb://type=AvatarHeadShot&id=" .. userId .. "&w=420&h=420"
        
        NotificationSound:Play()
        
        if table.find(DeveloperList, username) then
            NewMessage.Sender.Text = username .. " (Dev) " .. "(" .. decodedData.gamePlaying .. ")"
        else
            NewMessage.Sender.Text = username .. " (" .. decodedData.gamePlaying .. ")"
        end
        NewMessage.Visible = true
    end)
    
    local WelcomeMessage = {
        type = "message",
        username = "Server",
        message = "Make Sure To Join Our Discord Server = ( https://discord.gg/TPtrJceCva )",
        userid = 1,
        gamePlaying = "DataBase",
        gameid = game.PlaceId
    }
