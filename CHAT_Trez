--// Lógica Principal
local function MainFunction()
    local NoticeSound = Instance.new("Sound")
    NoticeSound.SoundId = "rbxassetid://2865226708"
    NoticeSound.Name = "NoticeReciveSound"
    NoticeSound.Parent = G2L.ScreenGui
    
    local SendSound = Instance.new("Sound")
    SendSound.SoundId = "rbxassetid://5485567028"
    SendSound.Name = "SendSound"
    SendSound.Parent = G2L.ScreenGui
    
    local Main = G2L.Main
    local ChatHistory = G2L.ChatHistory
    local SendAsync = G2L.SendButton
    local SourceChat = G2L.SourceChat
    local ChatExample = G2L.ChatTemplate
    ChatExample.Visible = false
    
    local Developer = {
        "C00lHamo0t2025",
        "ikik9i4"
    }

    local function CheckIfAdmin(player)
        return table.find(Developer, player.Name) ~= nil
    end

    local function FindPlayer(str)
        str = string.lower(str)
        for _, plr in ipairs(Players:GetPlayers()) do
            if string.sub(string.lower(plr.Name), 1, #str) == str then
                return plr
            end
        end
    end

    function AdminArg.Ban(player)
        if not CheckIfAdmin(Player) or not player then return end
        table.insert(BannedPeople, player.UserId)
    end

    function AdminArg.warn(player, reason)
        if not CheckIfAdmin(Player) or not player then return end

        local DataContent = {
            type = "message",
            username = "Server",
            message = player.Name .. " has been warned by " .. Player.Name .. " for " .. (reason or "No reason"),
            userid = 1,
            gamePlaying = "DataBase",
            gameid = game.PlaceId
        }

        getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
    end

    function AdminArg.unban(player)
        if not CheckIfAdmin(Player) or not player then return end

        local index = table.find(BannedPeople, player.UserId)
        if index then
            table.remove(BannedPeople, index)
        end
    end

    local AdminCommands = {
        ban = AdminArg.Ban,
        warn = AdminArg.warn,
        unban = AdminArg.unban
    }

    local function HandleCommand(text)
        local split = string.split(text, " ")
        if split[1] ~= "?" then return end

        local targetPlayer = FindPlayer(split[3])
        if AdminCommands[split[2]] then
            AdminCommands[split[2]](targetPlayer, split[4])
        end
    end

    getgenv().trezchat = WebSocket.connect("wss://free.blr2.piesocket.com/v3/1?api_key=eLudeCBiiTiQSr6DWJPMPfpZK9B6ghEu90ZbJwzm&notify_self=1")

    local function sendMessage()
        if SourceChat.Text == "" then return end
        
        HandleCommand(SourceChat.Text)

        -- Uso de task.spawn para evitar que el request HTTP congele la UI
        task.spawn(function()
            local success, result = pcall(function()
                local encodedWord = HttpService:UrlEncode(SourceChat.Text)
                return game:HttpGet("https://www.purgomalum.com/service/plain?text=" .. encodedWord)
            end)

            if success then
                local DataContent = {
                    type = "message",
                    username = Player.Name,
                    message = result,
                    userid = Player.UserId,
                    gamePlaying = MarketplaceService:GetProductInfo(game.PlaceId).Name,
                    gameid = game.PlaceId
                }
                getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
            else
                warn("Failed to filter message:", result)
            end
        end)

        SendSound:Play()
        SourceChat.Text = ""
    end

    SendAsync.MouseButton1Click:Connect(sendMessage)
    SourceChat.FocusLost:Connect(function(enterPressed)
        if enterPressed then sendMessage() end
    end)

    getgenv().trezchat.OnMessage:Connect(function(msg)
        local success, Decoded = pcall(HttpService.JSONDecode, HttpService, msg)
        if not success then
            warn("Failed to decode message:", msg)
            return
        end

        local Clone = ChatExample:Clone()
        Clone.Name = (Decoded.username or "Unknown") .. " Chats"
        Clone.MessageSource.Text = Decoded.message or ""
        Clone.PlayerIcon.Image = "rbxthumb://type=AvatarHeadShot&id=" .. (Decoded.userid or 0) .. "&w=420&h=420"
        
        NoticeSound:Play()

        if table.find(Developer, Decoded.username) then
            Clone.Sender.Text = Decoded.username .. " ( Dev ) ( " .. (Decoded.gamePlaying or "N/A") .. " )"
        else
            Clone.Sender.Text = Decoded.username .. " ( " .. (Decoded.gamePlaying or "N/A") .. " )"
        end
        
        Clone.Parent = ChatHistory
        Clone.Visible = true
    end)

    local welcomeMsg = {
        type = "message",
        username = "Server",
        message = "Make Sure To Join Our Discord Server = ( https://discord.gg/TPtrJceCva )",
        userid = 1,
        gamePlaying = "DataBase",
        gameid = game.PlaceId
    }
    getgenv().trezchat:Send(HttpService:JSONEncode(welcomeMsg))

    local messages = {
        "Be Careful Do Not Share Your Personal Info !!",
        "Make Sure To Join Our Discord Server = ( https://discord.gg/TPtrJceCva )",
        "if you saw any bug you can send the screen record of the issue to our discord server in #report channel so we can sole it"
    }
    
    -- task.spawn separado para el bucle de mensajes
    task.spawn(function()
        local msgIndex = 1
        while true do
            task.wait(1000) 
            
            local DataContent = {
                type = "message",
                username = "Server",
                message = messages[msgIndex],
                userid = 1,
                gamePlaying = "DataBase",
                gameid = game.PlaceId
            }
            
            getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
            
            msgIndex = msgIndex + 1
            if msgIndex > #messages then
                msgIndex = 1
            end
        end
    end)
end
task.spawn(MainFunction)

--// Lógica de Arrastre (Optimizada sin TweenService ni Memory Leaks)
local function UIDragFunction()
    local frame = G2L.Main
    local dragging, dragInput, dragStart, startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end
task.spawn(UIDragFunction)

--// Lógica del Canvas del Chat
local function CanvasFunction()
    local ChatHistory = G2L.ChatHistory
    local Layout = G2L.ChatLayout
    
    ChatHistory.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local function Update()
        ChatHistory.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
    end
    
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(Update)
end
task.spawn(CanvasFunction)

return G2L.ScreenGui
