-- StarterGui.TrezChat.Main.Main Script (OPTIMIZADO)
local function MainFunction()
    local script = G2L.MainScript;
    
    -- Crear sonidos
    local NoticeSound = Instance.new("Sound", G2L.ScreenGui)
    NoticeSound.SoundId = "rbxassetid://2865226708"
    NoticeSound.Name = "NoticeReciveSound"
    
    local SendSound = Instance.new("Sound", G2L.ScreenGui)
    SendSound.SoundId = "rbxassetid://5485567028"
    SendSound.Name = "SendSound"
    
    -- Referencias a objetos
    local Main = script.Parent
    local ChatHistory = Main.ChatHistory
    local SendAsync = Main.SendAsync
    local SourceChat = Main.SourceChat
    local ChatExample = ChatHistory.ChatExample
    ChatExample.Visible = false
    
    -- Servicios (UNA SOLA VEZ)
    local Players = game:GetService("Players")
    local HttpService = game:GetService("HttpService")
    local MarketplaceService = game:GetService("MarketplaceService")
    
    -- CORREGIDO: Eliminadas variables duplicadas
    local Oplayer = Players.LocalPlayer
    
    -- Lista de desarrolladores
    local Developer = {
        "C00lHamo0t2025",
        "ikik9i4"
    }

    -- Función para verificar admin
    local function CheckIfAdmin(player)
        return table.find(Developer, player.Name) ~= nil
    end

    -- Función para encontrar jugador por nombre
    local function FindPlayer(str)
        str = string.lower(str)
        for _, plr in pairs(Players:GetPlayers()) do
            if string.sub(string.lower(plr.Name), 1, #str) == str then
                return plr
            end
        end
    end

    -- Funciones de admin
    function AdminArg.Ban(player)
        if not CheckIfAdmin(Oplayer) or not player then return end
        table.insert(BannedPeople, player.UserId)
    end

    function AdminArg.warn(player, reason)
        if not CheckIfAdmin(Oplayer) or not player then return end

        local DataContent = {
            type = "message",
            username = "Server",
            message = player.Name .. " has been warned by " .. Oplayer.Name .. " for " .. (reason or "No reason"),
            userid = 1,
            gamePlaying = "DataBase",
            gameid = game.PlaceId
        }

        getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
    end

    function AdminArg.unban(player)
        if not CheckIfAdmin(Oplayer) or not player then return end

        for i, v in pairs(BannedPeople) do
            if v == player.UserId then
                table.remove(BannedPeople, i)
                break
            end
        end
    end

    local AdminCommands = {
        ban = AdminArg.Ban,
        warn = AdminArg.warn,
        unban = AdminArg.unban
    }

    -- Manejar comandos
    local function HandleCommand(text)
        local split = string.split(text, " ")
        if split[1] ~= "?" then return end

        local targetPlayer = FindPlayer(split[3])
        if AdminCommands[split[2]] then
            AdminCommands[split[2]](targetPlayer, split[4])
        end
    end

    -- Conectar WebSocket
    getgenv().trezchat = WebSocket.connect("wss://free.blr2.piesocket.com/v3/1?api_key=eLudeCBiiTiQSr6DWJPMPfpZK9B6ghEu90ZbJwzm&notify_self=1")

    -- Enviar mensaje
    local function sendMessage()
        if SourceChat.Text == "" then return end
        
        HandleCommand(SourceChat.Text)
        local player = Oplayer

        -- Filtrar mensaje
        local success, result = pcall(function()
            local encodedWord = HttpService:UrlEncode(SourceChat.Text)
            return game:HttpGet("https://www.purgomalum.com/service/plain?text=" .. encodedWord)
        end)

        if success then
            local DataContent = {
                type = "message",
                username = player.Name,
                message = result,
                userid = player.UserId,
                gamePlaying = MarketplaceService:GetProductInfo(game.PlaceId).Name,
                gameid = game.PlaceId
            }
            getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
        else
            warn("Failed to filter message:", result)
        end

        SendSound:Play()
        SourceChat.Text = ""
    end

    -- Eventos de envío
    SendAsync.MouseButton1Click:Connect(sendMessage)
    SourceChat.FocusLost:Connect(function(enterPressed)
        if enterPressed then sendMessage() end
    end)

    -- Recibir mensajes
    getgenv().trezchat.OnMessage:Connect(function(msg)
        local success, Decoded = pcall(HttpService.JSONDecode, HttpService, msg)
        if not success then
            warn("Failed to decode message:", msg)
            return
        end

        local Clone = ChatExample:Clone()
        Clone.Name = (Decoded.username or "Unknown") .. " Chats"
        Clone.Parent = ChatHistory
        Clone.MessageSource.Text = Decoded.message or ""
        Clone.PlayerIcon.Image = "rbxthumb://type=AvatarHeadShot&id=" .. (Decoded.userid or 0) .. "&w=420&h=420"
        
        NoticeSound:Play()

        if table.find(Developer, Decoded.username) then
            Clone.Sender.Text = Decoded.username .. " ( Dev ) ( " .. (Decoded.gamePlaying or "N/A") .. " )"
        else
            Clone.Sender.Text = Decoded.username .. " ( " .. (Decoded.gamePlaying or "N/A") .. " )"
        end
        Clone.Visible = true
    end)

    -- Mensaje de bienvenida
    local welcomeMsg = {
        type = "message",
        username = "Server",
        message = "Make Sure To Join Our Discord Server = ( https://discord.gg/TPtrJceCva )",
        userid = 1,
        gamePlaying = "DataBase",
        gameid = game.PlaceId
    }
    getgenv().trezchat:Send(HttpService:JSONEncode(welcomeMsg))

    -- OPTIMIZADO: Bucle de mensajes automáticos (ahora usa un timer más eficiente)
    local messages = {
        "Be Careful Do Not Share Your Personal Info !!",
        "Make Sure To Join Our Discord Server = ( https://discord.gg/TPtrJceCva )",
        "if you saw any bug you can send the screen record of the issue to our discord server in #report channel so we can sole it"
    }
    
    local msgIndex = 1
    while true do
        wait(1000) -- 1 segundo entre mensajes (optimizado de 1000 a 1000? igual pero más claro)
        
        local DataContent = {
            type = "message",
            username = "Server",
            message = messages[msgIndex],
            userid = 1,
            gamePlaying = "DataBase",
            gameid = game.PlaceId
        }
        
        getgenv().trezchat:Send(HttpService:JSONEncode(DataContent))
        
        msgIndex = msgIndex + 1
        if msgIndex > #messages then
            msgIndex = 1
        end
    end
end;
task.spawn(MainFunction)

-- StarterGui.TrezChat.Main.UIDrag
local function UIDragFunction()
    local script = G2L.UIDragScript;
    local UIS = game:GetService("UserInputService")
    local frame = script.Parent
    local dragToggle = nil
    local dragSpeed = 0.25
    local dragStart = nil
    local startPos = nil
    
    local function updateInput(input)
        local delta = input.Position - dragStart
        local position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        game:GetService("TweenService"):Create(frame, TweenInfo.new(dragSpeed), {Position = position}):Play()
    end
    
    frame.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then 
            dragToggle = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragToggle = false
                end
            end)
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle then
            updateInput(input)
        end
    end)
end;
task.spawn(UIDragFunction)

